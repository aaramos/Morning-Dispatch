# Real values belong in .env, which is ignored by git.
# Use absolute paths. Docker Compose does not reliably expand "~" in volume mounts.
MORNING_DISPATCH_HOME=~/.morning-dispatch
MORNING_DISPATCH_DATA_DIR=~/.morning-dispatch/data
MORNING_DISPATCH_SECRETS_DIR=~/.morning-dispatch/secrets
MORNING_DISPATCH_DB_PATH=~/.morning-dispatch/data/db/morning_dispatch.sqlite3
MORNING_DISPATCH_GMAIL_CLIENT_SECRET_PATH=~/.morning-dispatch/secrets/gmail/gmail_client_secret.json
MORNING_DISPATCH_GMAIL_CREDENTIALS_PATH=~/.morning-dispatch/secrets/gmail/gmail_credentials.json
MORNING_DISPATCH_PUBLIC_BASE_URL=http://127.0.0.1:8000
MORNING_DISPATCH_GMAIL_REMOTE_MCP_ENABLED=false

# Local Librarian model enrichment. The app falls back to deterministic enrichment
# when this is off or the model request fails.
MORNING_DISPATCH_LIBRARIAN_USE_MODEL=auto
MORNING_DISPATCH_MODEL_BASE_URL=http://127.0.0.1:1234/v1
MORNING_DISPATCH_LIBRARIAN_MODEL=Qwen3.6-27B-oQ8-mtp
MORNING_DISPATCH_LIBRARIAN_MODEL_MAX_ITEMS=250
MORNING_DISPATCH_MODEL_API_KEY=
MORNING_DISPATCH_MODEL_CONCURRENCY=1
MORNING_DISPATCH_MODEL_TIMEOUT_SECONDS=45

# Optional web search discovery provider.
# Supported: auto, tavily, brave, serpapi
# If no Morning Dispatch key is set, the app can reuse matching keys from this
# shared env file, such as BRAVE_SEARCH_API_KEY or TAVILY_API_KEY.
MORNING_DISPATCH_WEB_SEARCH_PROVIDER=auto
MORNING_DISPATCH_SHARED_SEARCH_ENV_PATH=~/.hermes/.env
MORNING_DISPATCH_TAVILY_API_KEY=
MORNING_DISPATCH_BRAVE_API_KEY=
MORNING_DISPATCH_SERPAPI_API_KEY=

# Optional YouTube discovery with native transcript extraction.
MORNING_DISPATCH_YOUTUBE_API_KEY=
MORNING_DISPATCH_YOUTUBE_MAX_RESULTS=15
MORNING_DISPATCH_YOUTUBE_DURATION_FILTER=medium

# Optional local Collections source.
MORNING_DISPATCH_COLLECTIONS_ROOT=~/Documents/Collections
MORNING_DISPATCH_COLLECTIONS_MAX_RESULTS=12
MORNING_DISPATCH_COLLECTIONS_MAX_FILE_BYTES=1000000

# Optional Markets source. Simple mode uses free public market data.
MORNING_DISPATCH_MARKETS_MODE=simple
MORNING_DISPATCH_MARKETS_MAX_CORE_COMPANIES=5
MORNING_DISPATCH_MARKETS_MAX_RELATED_COMPANIES=5

# Optional podcast discovery and transcription.
# Manual podcast RSS feeds work without Podcast Index credentials.
MORNING_DISPATCH_PODCASTINDEX_API_KEY=
MORNING_DISPATCH_PODCASTINDEX_API_SECRET=
MORNING_DISPATCH_PODCAST_TRANSCRIBE_COMMAND=
